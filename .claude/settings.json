{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(claude -p*)",
      "Bash(claude --print*)",
      "PowerShell(claude -p*)",
      "PowerShell(claude --print*)"
    ],
    "allow": [
      "Bash(wiki *)",
      "Bash(git *)",
      "PowerShell(wiki *)",
      "PowerShell(git *)",
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)"
    ]
  },
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_end.py\""
          }
        ]
      }
    ]
  }
}
